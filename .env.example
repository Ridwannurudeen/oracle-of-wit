# Oracle of Wit - Environment Variables
# Copy this file to .env and fill in your values

# Upstash Redis (https://upstash.com)
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token_here

# GenLayer Intelligent Contracts — REQUIRED (https://studio.genlayer.com)
# GenLayer is the sole judging backbone. App will not start without these.
GENLAYER_RPC_URL=https://studio.genlayer.com/api
GENLAYER_CONTRACT_ADDRESS=0x0E544D28E1136A6bA0E65debc60cDAEBE5557a69
GENLAYER_PRIVATE_KEY=

# Discord Webhook (optional — posts game results to a channel)
DISCORD_WEBHOOK_URL=

# Discord Bot (slash commands via Interactions API)
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=

# Timers (ms)
SUBMISSION_TIME=40000
BETTING_TIME=30000

# GenLayer
GL_POLL_TIMEOUT=30000

# Auth
SESSION_TTL=7200
RATE_LIMIT_PER_MINUTE=60

# Monitoring
SLOW_REQUEST_MS=3000

# Vercel Cron (auto-set by Vercel, or set manually for local testing)
CRON_SECRET=
